# Copiez vers .env et renseignez les valeurs. Ne commitez pas .env.

PORT=5000
DB_URL=file:local.db
DB_AUTH_TOKEN=
JWT_SECRET=change_me_to_a_long_random_string

# --- E-mail — choix A : Resend (https://resend.com)
RESEND_API_KEY=
# Adresse d’expéditeur (domaine vérifié chez Resend)
EMAIL_FROM=

# --- E-mail — choix B : Gmail (SMTP) + mot de passe d’application
# 1) 2-Step Verification = On : https://myaccount.google.com/security
# 2) Créer un mot de passe d’application : https://myaccount.google.com/apppasswords
#    (16 caractères — vous pouvez coller avec ou sans espaces dans .env)
# 3) Copier les valeurs dans votre fichier .env local (pas dans git).
# Si « App passwords » est indisponible : compte Workspace ou politique admin → utiliser Resend.
# https://support.google.com/accounts/answer/185833
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Optionnel : nom affiché comme expéditeur
# GMAIL_FROM_NAME=Mon entreprise
# Si vous renseignez aussi EMAIL_FROM, il sert d’adresse « From » (doit être l’e-mail Gmail ou un alias validé).
# EMAIL_FROM=

# Si Resend ET Gmail sont tous les deux remplis, lequel utiliser ? (défaut : resend)
# EMAIL_PROVIDER=resend
# EMAIL_PROVIDER=gmail

# --- WhatsApp — option A (simple) : UltraMsg — https://ultramsg.com
# Créez un compte → nouvelle instance → scannez le QR avec WhatsApp Business (ou le numéro indiqué).
# Copiez l’ID d’instance et le token depuis le tableau de bord.
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=

# --- WhatsApp — option B : Meta Cloud API (développeurs Meta)
# https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optionnel (défaut v21.0)
# WHATSAPP_API_VERSION=v21.0

# Si Meta exige un modèle approuvé pour le premier message :
# WHATSAPP_TEMPLATE_NAME=votre_modele
# WHATSAPP_TEMPLATE_LANG=fr
# Modèle sans variable de corps (ex. hello_world) :
# WHATSAPP_TEMPLATE_NO_BODY_VARS=1

# --- WhatsApp — option C : Twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Si UltraMsg + Meta (ou Twilio) sont tous remplis, lequel utiliser ? (défaut : ultramsg)
# WHATSAPP_PROVIDER=ultramsg
# WHATSAPP_PROVIDER=meta
# WHATSAPP_PROVIDER=twilio

# Normalisation des numéros marocains (0XXXXXXXXX -> 212XXXXXXXXX)
DEFAULT_PHONE_COUNTRY_CODE=212
